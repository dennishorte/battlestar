# Override these in api/.env (gitignored) when running scripts that need
# remote MongoDB credentials.

# Full mongo URI used by api/scripts/update_magic_via_tunnel.sh.
# Default is mongodb://localhost:<MAGIC_UPDATE_LOCAL_PORT>/game-center which
# works only if the prod Mongo behind the tunnel requires no authentication.
# If prod Mongo has auth, put the credentials here:
# MONGODB_URI=mongodb://USER:PASSWORD@localhost:27018/game-center?authSource=admin

# Optional tunnel overrides:
# MAGIC_UPDATE_SSH_HOST=vue
# MAGIC_UPDATE_LOCAL_PORT=27018
# MAGIC_UPDATE_REMOTE_PORT=27017
