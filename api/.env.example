# Override these in api/.env (gitignored).

# Local dev MongoDB URI. Used by the api dev server (`npm run dev`) and by
# `npm run magic:update:local`.
# MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/game-center?authSource=admin

# Prod MongoDB URI for `npm run magic:update`. The wrapper script opens an
# SSH tunnel and connects via this URI; the default below assumes prod Mongo
# requires no authentication. If it does, set credentials here:
# PROD_MONGODB_URI=mongodb://USER:PASSWORD@localhost:27018/game-center?authSource=admin

# Optional tunnel overrides:
# MAGIC_UPDATE_SSH_HOST=vue
# MAGIC_UPDATE_LOCAL_PORT=27018
# MAGIC_UPDATE_REMOTE_PORT=27017
